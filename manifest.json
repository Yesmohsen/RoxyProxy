{
  "manifest_version": 3,
  "name": "RoxyProxy",
  "version": "1.0.0",
  "description": "Modern Proxy Manager for Chrome – Easy & Fast",
  "permissions": [
    "proxy",
    "storage",
    "webRequest",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "RoxyProxy",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
